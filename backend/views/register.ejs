<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MemoryVerse — Register</title>
  <link rel="stylesheet" href="/style.css" />
</head>

<body class="auth-page">

  <div class="auth-visual">
    <div class="reel-line"></div>
    <div class="visual-top">
      <span class="eyebrow">Reel 000 — New Archive</span>
      <h1 class="logo">MemoryVerse</h1>
    </div>

    <div class="visual-body">
      <h2>Start a story only you could tell.</h2>
      <p>Create your archive and turn everyday moments into a timeline worth replaying.</p>

      <div class="filmstrip-row">
        <div class="frame" style="background-image:url('https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=300&q=60')"></div>
        <div class="frame" style="background-image:url('https://images.unsplash.com/photo-1526772662000-3f88f10405ff?auto=format&fit=crop&w=300&q=60')"></div>
        <div class="frame" style="background-image:url('https://images.unsplash.com/photo-1511988617509-a57c8a288659?auto=format&fit=crop&w=300&q=60')"></div>
        <div class="frame" style="background-image:url('https://images.unsplash.com/photo-1519046904884-53103b34b206?auto=format&fit=crop&w=300&q=60')"></div>
      </div>
    </div>

    <span class="visual-foot">EST. YOUR ARCHIVE — ALWAYS ROLLING</span>
  </div>

  <div class="auth-form-side">
    <div class="container">
      <div class="card">
        <h1 class="auth-logo">Create account</h1>
        <p class="auth-subtitle">Start collecting your favorite memories</p>

        <form id="registerForm">
          <div class="input-group">
            <input
              type="text"
              id="username"
              placeholder="Enter username"
              required
            />
            <span class="input-icon">👤</span>
          </div>

          <div class="input-group">
            <input
              type="email"
              id="email"
              placeholder="Enter email"
              required
            />
            <span class="input-icon">✉</span>
          </div>

          <div class="input-group">
            <input
              type="password"
              id="password"
              placeholder="Enter password"
              required
            />
            <span class="input-icon">🔒</span>
          </div>

          <button type="submit" class="auth-btn">Register</button>
        </form>

        <div class="auth-footer">
          Already have an account?
          <a href="/login">Login</a>
        </div>
      </div>
    </div>
  </div>

  <script src="/app.js"></script>
</body>

</html>
