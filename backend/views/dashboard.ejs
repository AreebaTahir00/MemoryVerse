<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MemoryVerse — Dashboard</title>
  <link rel="stylesheet" href="/style.css" />
</head>

<body class="dashboard-page">
  <section class="hero">
    <nav class="navbar">
      <h1 class="logo">MemoryVerse</h1>

      <div class="nav-buttons">
        <a href="/timeline">
          <button>Timeline</button>
        </a>

        <a href="/add-memory">
          <button>Add Memory</button>
        </a>
      </div>
    </nav>

    <div class="hero-content">
      <div class="hero-left">
        <h1>
          Preserve Your
          <span>Beautiful Memories</span>
        </h1>

        <p>
          A cinematic digital memory platform where your moments become timeless stories.
        </p>
      </div>

      <div class="hero-right">
        <div class="floating-card card1">
          <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=600&q=70" alt="Landscape memory" />
        </div>

        <div class="floating-card card2">
          <img src="https://images.unsplash.com/photo-1526772662000-3f88f10405ff?auto=format&fit=crop&w=600&q=70" alt="Travel memory" />
        </div>

        <div class="floating-card card3">
          <img src="https://images.unsplash.com/photo-1511988617509-a57c8a288659?auto=format&fit=crop&w=600&q=70" alt="City memory" />
        </div>
      </div>
    </div>
  </section>
</body>

</html>
